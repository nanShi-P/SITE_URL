---
import '../styles/global.css';
import CategoryNav from '../components/CategoryNav.astro';
import SearchBox from '../components/SearchBox.astro';
import SiteCounter from '../components/SiteCounter.astro';
interface Props { title: string; description: string; canonical?: string; }
const { title, description, canonical } = Astro.props;
const url = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const gcCode = import.meta.env.PUBLIC_GOATCOUNTER_CODE;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (() => {
        try {
          if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
          }
        } catch {}
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <!-- AdSense 脚本占位：审核通过后取消注释并填 client id
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXX" crossorigin="anonymous"></script>
    -->
    {gcCode && (
      <script
        data-goatcounter={`https://${gcCode}.goatcounter.com/count`}
        async
        src="//gc.zgo.at/count.js"
      ></script>
    )}
  </head>
  <body class="bg-neutral-50 text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100 min-h-screen flex flex-col">
    <header class="border-b border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 relative">
      <div class="max-w-5xl mx-auto px-4 pt-4 lg:py-3 flex flex-wrap lg:flex-nowrap items-center gap-3">
        <a href={base} class="font-bold text-lg shrink-0 dark:text-neutral-100">AI 开源榜</a>
        <button
          id="theme-toggle"
          type="button"
          aria-label="切换暗色模式"
          class="ml-auto lg:ml-0 lg:order-last shrink-0 p-2 text-lg leading-none text-neutral-600 hover:text-neutral-900 dark:text-neutral-300 dark:hover:text-white"
        >
          <span class="theme-icon-light">☀️</span>
          <span class="theme-icon-dark hidden">🌙</span>
        </button>
        <input id="nav-toggle" type="checkbox" class="peer hidden" aria-label="菜单" />
        <label for="nav-toggle" class="hamburger lg:hidden cursor-pointer select-none p-2 -mr-2" aria-controls="mobile-drawer">
          <span class="hb-bar"></span>
          <span class="hb-bar"></span>
          <span class="hb-bar"></span>
        </label>
        <div class="hidden lg:block lg:flex-1"><CategoryNav /></div>
        <div class="order-last lg:order-none w-full lg:w-72 pb-4 lg:pb-0"><SearchBox /></div>
        <div id="mobile-drawer"
             class="mobile-drawer lg:hidden absolute left-0 right-0 top-full bg-white dark:bg-neutral-900 border-t border-neutral-200 dark:border-neutral-800 shadow-lg z-40">
          <CategoryNav mobile={true} />
        </div>
      </div>
      <style>
        .hamburger {
          display: inline-flex;
          flex-direction: column;
          justify-content: center;
          gap: 5px;
          width: 40px;
          height: 40px;
          align-items: center;
        }
        .hb-bar {
          display: block;
          width: 22px;
          height: 2px;
          background: #1f2937;
          border-radius: 2px;
          transition: transform 220ms ease, opacity 180ms ease;
          transform-origin: center;
        }
        .dark .hb-bar { background: #e5e7eb; }
        #nav-toggle:checked ~ .hamburger .hb-bar:nth-child(1) {
          transform: translateY(7px) rotate(45deg);
        }
        #nav-toggle:checked ~ .hamburger .hb-bar:nth-child(2) {
          opacity: 0;
          transform: scaleX(0);
        }
        #nav-toggle:checked ~ .hamburger .hb-bar:nth-child(3) {
          transform: translateY(-7px) rotate(-45deg);
        }
        .mobile-drawer {
          opacity: 0;
          transform: translateY(-8px);
          pointer-events: none;
          visibility: hidden;
          transition: opacity 200ms ease, transform 220ms ease, visibility 0s linear 220ms;
        }
        #nav-toggle:checked ~ .mobile-drawer,
        #nav-toggle:checked ~ div .mobile-drawer {
          opacity: 1;
          transform: translateY(0);
          pointer-events: auto;
          visibility: visible;
          transition: opacity 200ms ease, transform 220ms ease, visibility 0s;
        }
        @media (prefers-reduced-motion: reduce) {
          .hb-bar, .mobile-drawer { transition: none !important; }
        }
      </style>
      <script is:inline>
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            const t = document.getElementById('nav-toggle');
            if (t && t.checked) t.checked = false;
          }
        });
        (() => {
          const btn = document.getElementById('theme-toggle');
          if (!btn) return;
          const sun = btn.querySelector('.theme-icon-light');
          const moon = btn.querySelector('.theme-icon-dark');
          function sync() {
            const isDark = document.documentElement.classList.contains('dark');
            sun.classList.toggle('hidden', isDark);
            moon.classList.toggle('hidden', !isDark);
          }
          sync();
          btn.addEventListener('click', () => {
            const next = !document.documentElement.classList.contains('dark');
            document.documentElement.classList.toggle('dark', next);
            try { localStorage.setItem('theme', next ? 'dark' : 'light'); } catch {}
            sync();
          });
        })();
      </script>
    </header>
    <main class="flex-1 max-w-5xl mx-auto px-4 py-8 w-full"><slot /></main>
    <footer class="border-t border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900">
      <div class="max-w-5xl mx-auto px-4 py-6 text-sm text-neutral-600 dark:text-neutral-400 flex flex-wrap gap-4 items-center">
        <a href={`${base}about`}>关于</a><a href={`${base}privacy`}>隐私</a>
        <a href={`${base}terms`}>条款</a><a href={`${base}contact`}>联系</a>
        <SiteCounter />
      </div>
    </footer>
  </body>
</html>
