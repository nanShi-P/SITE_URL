---
import '../styles/global.css';
import CategoryNav from '../components/CategoryNav.astro';
import SearchBox from '../components/SearchBox.astro';
import SiteCounter from '../components/SiteCounter.astro';
interface Props { title: string; description: string; canonical?: string; }
const { title, description, canonical } = Astro.props;
const url = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const gcCode = import.meta.env.PUBLIC_GOATCOUNTER_CODE;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <!-- AdSense 脚本占位：审核通过后取消注释并填 client id
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXX" crossorigin="anonymous"></script>
    -->
    {gcCode && (
      <script
        data-goatcounter={`https://${gcCode}.goatcounter.com/count`}
        async
        src="//gc.zgo.at/count.js"
      ></script>
    )}
  </head>
  <body class="bg-neutral-50 text-neutral-900 min-h-screen flex flex-col">
    <header class="border-b bg-white relative">
      <div class="max-w-5xl mx-auto px-4 pt-4 md:py-4 flex flex-wrap md:flex-nowrap items-center gap-3">
        <a href={base} class="font-bold text-lg shrink-0">AI 开源榜</a>
        <input id="nav-toggle" type="checkbox" class="peer hidden" aria-label="菜单" />
        <label for="nav-toggle" class="hamburger md:hidden ml-auto cursor-pointer select-none p-2 -mr-2" aria-controls="mobile-drawer">
          <span class="hb-bar"></span>
          <span class="hb-bar"></span>
          <span class="hb-bar"></span>
        </label>
        <div class="order-last md:order-none w-full md:w-auto md:flex-1 pb-4 md:pb-0"><SearchBox /></div>
        <div class="hidden md:block"><CategoryNav /></div>
        <div id="mobile-drawer"
             class="mobile-drawer md:hidden absolute left-0 right-0 top-full bg-white border-t shadow-lg z-40">
          <CategoryNav mobile={true} />
        </div>
      </div>
      <style>
        .hamburger {
          display: inline-flex;
          flex-direction: column;
          justify-content: center;
          gap: 5px;
          width: 40px;
          height: 40px;
          align-items: center;
        }
        .hb-bar {
          display: block;
          width: 22px;
          height: 2px;
          background: #1f2937;
          border-radius: 2px;
          transition: transform 220ms ease, opacity 180ms ease;
          transform-origin: center;
        }
        #nav-toggle:checked ~ .hamburger .hb-bar:nth-child(1) {
          transform: translateY(7px) rotate(45deg);
        }
        #nav-toggle:checked ~ .hamburger .hb-bar:nth-child(2) {
          opacity: 0;
          transform: scaleX(0);
        }
        #nav-toggle:checked ~ .hamburger .hb-bar:nth-child(3) {
          transform: translateY(-7px) rotate(-45deg);
        }
        .mobile-drawer {
          opacity: 0;
          transform: translateY(-8px);
          pointer-events: none;
          visibility: hidden;
          transition: opacity 200ms ease, transform 220ms ease, visibility 0s linear 220ms;
        }
        #nav-toggle:checked ~ .mobile-drawer,
        #nav-toggle:checked ~ div .mobile-drawer {
          opacity: 1;
          transform: translateY(0);
          pointer-events: auto;
          visibility: visible;
          transition: opacity 200ms ease, transform 220ms ease, visibility 0s;
        }
        @media (prefers-reduced-motion: reduce) {
          .hb-bar, .mobile-drawer { transition: none !important; }
        }
      </style>
      <script is:inline>
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            const t = document.getElementById('nav-toggle');
            if (t && t.checked) t.checked = false;
          }
        });
      </script>
    </header>
    <main class="flex-1 max-w-5xl mx-auto px-4 py-8 w-full"><slot /></main>
    <footer class="border-t bg-white">
      <div class="max-w-5xl mx-auto px-4 py-6 text-sm text-neutral-600 flex flex-wrap gap-4 items-center">
        <a href={`${base}about`}>关于</a><a href={`${base}privacy`}>隐私</a>
        <a href={`${base}terms`}>条款</a><a href={`${base}contact`}>联系</a>
        <SiteCounter />
      </div>
    </footer>
  </body>
</html>
