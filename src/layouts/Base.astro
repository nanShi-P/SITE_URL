---
import '../styles/global.css';
import CategoryNav from '../components/CategoryNav.astro';
interface Props { title: string; description: string; canonical?: string; }
const { title, description, canonical } = Astro.props;
const url = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <!-- AdSense 脚本占位：审核通过后取消注释并填 client id
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXX" crossorigin="anonymous"></script>
    -->
  </head>
  <body class="bg-neutral-50 text-neutral-900 min-h-screen flex flex-col">
    <header class="border-b bg-white">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="font-bold text-lg">AI 开源榜</a>
        <CategoryNav />
      </div>
    </header>
    <main class="flex-1 max-w-5xl mx-auto px-4 py-8 w-full"><slot /></main>
    <footer class="border-t bg-white">
      <div class="max-w-5xl mx-auto px-4 py-6 text-sm text-neutral-600 flex gap-4">
        <a href="/about">关于</a><a href="/privacy">隐私</a>
        <a href="/terms">条款</a><a href="/contact">联系</a>
        <a href="/rss.xml">RSS</a>
      </div>
    </footer>
  </body>
</html>
