---
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import AdSlot from '../../../components/AdSlot.astro';
import StarChart from '../../../components/StarChart.astro';
import RepoCard from '../../../components/RepoCard.astro';
import { allRepos, getDigest, relatedRepos } from '../../../utils/data';
import { CATEGORIES } from '../../../../scripts/lib/categories';
import { repoTitle, repoDescription } from '../../../utils/seo';
import { formatStars } from '../../../utils/format';

export function getStaticPaths() {
  return allRepos.map(r => ({
    params: { owner: r.owner, name: r.name },
    props: { repo: r },
  }));
}
const { repo } = Astro.props;
const digest = getDigest(repo.id);
const related = relatedRepos(repo);
const categoryLabel = CATEGORIES.find(c => c.slug === repo.category)?.label ?? '其他';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: `${repo.owner}/${repo.name}`,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Cross-platform',
  url: repo.url,
  description: digest?.summary_zh ?? repo.description,
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.5', ratingCount: String(repo.stars) },
};
const chipClass = 'px-2 py-1 rounded border border-neutral-200 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-800';
---
<Base title={repoTitle(repo)} description={repoDescription(repo, digest)}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <Breadcrumb items={[
    { href: base, label: '首页' },
    { href: `${base}category/${repo.category}`, label: categoryLabel },
    { label: `${repo.owner}/${repo.name}` },
  ]} />

  <h1 class="font-mono text-2xl font-bold dark:text-neutral-100 break-all">{repo.owner}/{repo.name}</h1>
  <div class="flex flex-wrap gap-3 items-center text-sm text-neutral-600 dark:text-neutral-400 mt-2 mb-4">
    <span>⭐ {formatStars(repo.stars)}</span>
    {repo.language && <span class="px-2 py-0.5 bg-neutral-100 dark:bg-neutral-800 dark:text-neutral-300 rounded">{repo.language}</span>}
    <a href={repo.url} target="_blank" rel="noopener" class="text-blue-600 dark:text-blue-400 hover:underline">前往 GitHub →</a>
  </div>

  {digest && (
    <nav class="mb-4 flex flex-wrap gap-2 text-xs" aria-label="快速跳转">
      {digest.scenarios?.length > 0 && <a href="#scenarios" class={chipClass}>🎯 场景</a>}
      <a href="#difficulty" class={chipClass}>📊 难度</a>
      {digest.alternatives?.length > 0 && <a href="#alternatives" class={chipClass}>🔄 替代</a>}
      <a href="#stars" class={chipClass}>📈 走势</a>
      {repo.description && <a href="#readme" class={chipClass}>📖 原始</a>}
    </nav>
  )}

  {digest && <p class="text-base bg-blue-50 dark:bg-blue-900/30 border-l-4 border-blue-400 dark:border-blue-500 dark:text-neutral-100 p-3 my-4 leading-relaxed">📝 {digest.summary_zh}</p>}

  <AdSlot slot="repo-top" />

  {digest && (
    <section class="my-6 space-y-4">
      <div id="scenarios" class="scroll-mt-20">
        <h2 class="font-semibold mb-2 dark:text-neutral-100">🎯 适用场景</h2>
        <div class="flex flex-wrap gap-2">
          {digest.scenarios.map(s => <span class="px-3 py-1 bg-amber-50 border border-amber-200 rounded-full text-sm dark:bg-amber-900/30 dark:border-amber-800 dark:text-amber-300">{s}</span>)}
        </div>
      </div>
      <div id="difficulty" class="scroll-mt-20">
        <h2 class="font-semibold mb-1 dark:text-neutral-100">📊 上手难度：<span class="text-blue-700 dark:text-blue-400">{digest.difficulty}</span></h2>
        <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed">{digest.difficulty_reason}</p>
      </div>
      {digest.alternatives.length > 0 && (
        <div id="alternatives" class="scroll-mt-20">
          <h2 class="font-semibold mb-1 dark:text-neutral-100">🔄 同类替代</h2>
          <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed">{digest.alternatives.join(' · ')}</p>
        </div>
      )}
    </section>
  )}

  <div id="stars" class="scroll-mt-20">
    <StarChart stars={repo.stars} forks={repo.forks} />
  </div>

  <AdSlot slot="repo-mid" />

  {repo.description && (
    <section id="readme" class="scroll-mt-20 my-6">
      <h2 class="font-semibold mb-2 dark:text-neutral-100">📖 项目原始描述</h2>
      <p class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed">{repo.description}</p>
      <a href={repo.url} target="_blank" rel="noopener" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">→ 查看完整 README</a>
    </section>
  )}

  {related.length > 0 && (
    <section class="my-8">
      <h2 class="font-semibold mb-3 dark:text-neutral-100">🔗 同分类推荐</h2>
      <div class="grid gap-3">
        {related.map(r => <RepoCard repo={r} digest={getDigest(r.id)} />)}
      </div>
    </section>
  )}
</Base>
