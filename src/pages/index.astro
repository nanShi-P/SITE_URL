---
import Base from '../layouts/Base.astro';
import RepoCard from '../components/RepoCard.astro';
import AdSlot from '../components/AdSlot.astro';
import { allRepos, getDigest, dataUpdatedAt, trendingRepos } from '../utils/data';
import { CATEGORIES } from '../../scripts/lib/categories';
import { homeTitle, homeDescription } from '../utils/seo';

const top = allRepos.slice(0, 100);
const trending = trendingRepos(1000, 10);
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const updatedLabel = dataUpdatedAt.toLocaleString('zh-CN', {
  timeZone: 'Asia/Shanghai', year: 'numeric', month: '2-digit', day: '2-digit',
  hour: '2-digit', minute: '2-digit', hour12: false,
});
---
<Base title={homeTitle()} description={homeDescription()}>
  <h1 class="text-2xl font-bold mb-2">AI 开源项目中文榜单</h1>
  <p class="text-neutral-600 mb-1">收录 Top 500 个 GitHub AI 开源项目，每个都有中文一句话简介、适用场景、上手难度。</p>
  <p class="text-xs text-neutral-500 mb-6">数据更新时间：{updatedLabel}（北京时间）</p>

  <section class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
    {CATEGORIES.filter(c => c.slug !== 'other').map(c => (
      <a href={`${base}category/${c.slug}`} class="bg-white border rounded p-3 text-center hover:border-blue-400">
        {c.label}
      </a>
    ))}
  </section>

  {trending.length > 0 && (
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-4">📈 本周窜升</h2>
      <div class="grid gap-3 md:grid-cols-2">
        {trending.map(r => (
          <div class="relative">
            <span class="absolute top-2 right-2 z-10 text-xs font-semibold text-green-700 bg-green-50 border border-green-200 rounded px-1.5 py-0.5">
              ↑{r.rank_delta}
            </span>
            <RepoCard repo={r} digest={getDigest(r.id)} />
          </div>
        ))}
      </div>
    </section>
  )}

  <AdSlot slot="home-top" />

  <h2 class="text-xl font-semibold mb-4">Top 100 总榜</h2>
  <div class="grid gap-3">
    {top.map(r => <RepoCard repo={r} digest={getDigest(r.id)} />)}
  </div>
</Base>
