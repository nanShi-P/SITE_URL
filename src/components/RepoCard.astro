---
import { formatStars, formatDelta } from '../utils/format';
import type { Repo, Digest } from '../utils/data';
interface Props { repo: Repo; digest: Digest | null; }
const { repo, digest } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

const DIFFICULTY_STYLE: Record<string, string> = {
  '简单': 'bg-green-100 text-green-800 border-green-200',
  '中等': 'bg-yellow-100 text-yellow-800 border-yellow-200',
  '困难': 'bg-red-100 text-red-800 border-red-200',
};
const diffClass = digest ? (DIFFICULTY_STYLE[digest.difficulty] ?? 'bg-neutral-100 text-neutral-700 border-neutral-200') : '';
const scenarios = digest?.scenarios?.slice(0, 3) ?? [];
---
<article class="bg-white border rounded-lg p-4 hover:shadow-md transition">
  <div class="flex items-baseline gap-2">
    <a href={`${base}repo/${repo.owner}/${repo.name}`} class="text-lg font-semibold text-blue-700 hover:underline">
      {repo.owner}/{repo.name}
    </a>
    <span class="text-sm text-neutral-500">⭐ {formatStars(repo.stars)}</span>
    {repo.rank_delta !== 0 && (
      <span class={`text-xs ${repo.rank_delta > 0 ? 'text-green-600' : 'text-red-600'}`}>
        {formatDelta(repo.rank_delta)}
      </span>
    )}
  </div>
  {repo.language && <span class="text-xs text-neutral-500">{repo.language}</span>}
  <p class="mt-2 text-sm text-neutral-700">{digest?.summary_zh ?? repo.description}</p>
  {digest && (
    <div class="mt-3 flex flex-wrap items-center gap-2">
      <span class={`text-xs px-2 py-0.5 rounded border ${diffClass}`}>难度 · {digest.difficulty}</span>
      {scenarios.map(s => (
        <span class="text-xs px-2 py-0.5 rounded-full border border-amber-200 bg-amber-50 text-amber-800">{s}</span>
      ))}
    </div>
  )}
</article>
