---
import { formatStars, formatDelta } from '../utils/format';
import type { Repo, Digest } from '../utils/data';
interface Props { repo: Repo; digest: Digest | null; hideDelta?: boolean; }
const { repo, digest, hideDelta = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

const DIFF_LEVELS: Record<string, { filled: number; color: string; text: string }> = {
  '简单': { filled: 1, color: 'bg-green-500', text: 'text-green-700' },
  '中等': { filled: 2, color: 'bg-yellow-500', text: 'text-yellow-700' },
  '困难': { filled: 3, color: 'bg-red-500',    text: 'text-red-700' },
};
const diff = digest ? (DIFF_LEVELS[digest.difficulty] ?? { filled: 0, color: 'bg-neutral-400', text: 'text-neutral-600' }) : null;
const scenarios = digest?.scenarios?.slice(0, 3) ?? [];
---
<article class="bg-white dark:bg-neutral-900 border dark:border-neutral-700 rounded-lg p-4 hover:shadow-md transition h-full flex flex-col min-w-0">
  <div class="flex items-baseline gap-2 min-w-0">
    <a href={`${base}repo/${repo.owner}/${repo.name}`} class="font-mono text-lg font-semibold text-blue-700 dark:text-blue-400 hover:underline break-all min-w-0 flex-1">
      {repo.owner}/{repo.name}
    </a>
    <span class="text-sm text-neutral-500 dark:text-neutral-400 shrink-0">⭐ {formatStars(repo.stars)}</span>
    {!hideDelta && repo.rank_delta !== 0 && (
      <span class={`text-xs shrink-0 ${repo.rank_delta > 0 ? 'text-green-600' : 'text-red-600'}`}>
        {formatDelta(repo.rank_delta)}
      </span>
    )}
  </div>
  {repo.language && <span class="text-xs text-neutral-500 dark:text-neutral-400">{repo.language}</span>}
  <p class="mt-2 text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed line-clamp-2 min-h-[2.5rem]">{digest?.summary_zh ?? repo.description}</p>
  {digest && (
    <div class="mt-3 flex flex-wrap items-center gap-2">
      <span class="inline-flex items-center gap-1.5 text-xs">
        <span class="text-neutral-500 dark:text-neutral-400">难度</span>
        <span class="inline-flex gap-0.5">
          {[0, 1, 2].map(i => (
            <span class={`w-2 h-2 rounded-sm ${i < diff!.filled ? diff!.color : 'bg-neutral-200 dark:bg-neutral-700'}`}></span>
          ))}
        </span>
        <span class={`font-medium ${diff!.text}`}>{digest.difficulty}</span>
      </span>
      {scenarios.map(s => (
        <span class="text-xs px-2 py-0.5 rounded-full border border-amber-200 bg-amber-50 text-amber-800 dark:bg-amber-900/30 dark:border-amber-800 dark:text-amber-300">{s}</span>
      ))}
    </div>
  )}
</article>
